/*
 * Device Tree Overlay for Agriculture Robot - STM32F407VET
 *
 * Pin mapping:
 *   PA8  -> TIM1_CH1 -> PUL (step pulse to CL57C)
 *   PE2  -> GPIO OUT -> DIR (direction)
 *   PE3  -> GPIO OUT -> ENA (enable: HIGH=enable, LOW=disable)
 *   PE4  -> GPIO IN  -> ALM (alarm from CL57C, trigger on rising edge)
 *   PA2  -> USART2_TX -> CMD TX to master
 *   PA3  -> USART2_RX -> CMD RX from master
 */

/ {
    /*
     * Motor control GPIO pins grouped as a single node.
     * motor_hw reads these via DT_NODELABEL.
     */
    motor_gpios {
        compatible = "gpio-keys";
        status = "okay";

        motor_dir: motor_dir {
            gpios = <&gpioe 2 GPIO_ACTIVE_HIGH>;
            label = "Motor DIR";
        };

        motor_ena: motor_ena {
            gpios = <&gpioe 3 GPIO_ACTIVE_HIGH>;
            label = "Motor ENA";
        };

        motor_alm: motor_alm {
            gpios = <&gpioe 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
            label = "Motor ALM";
        };
    };

    chosen {
        zephyr,console = &usart2;
        zephyr,shell-uart = &usart2;
    };
};

/* TIM1 CH1 on PA8 - Step pulse output (PWM) */
&timers1 {
    status = "okay";
    /* Prescaler: 168MHz / (167+1) = 1MHz -> 1us resolution */
    st,prescaler = <167>;

    pwm1: pwm {
        status = "okay";
        pinctrl-0 = <&tim1_ch1_pa8>;
        pinctrl-names = "default";
        #pwm-cells = <3>;
    };
};

/* USART2 on PA2/PA3 for communication with master */
&usart2 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
    pinctrl-names = "default";
};
