# Telegram
BOT_TOKEN=8620459674:AAGRdwf14q8RjZbNGGPxCDagBBSksCgin5c
ALLOWED_CHAT_ID=8620459674
ALLOWED_GROUP_ID=0

# Comma-separated Telegram user IDs
ADMIN_USER_IDS=111111111
OPERATOR_USER_IDS=
VIEWER_USER_IDS=

# Farm robot project root. Default can be parent of telegram_control.
PROJECT_ROOT=d:\DOCUMENT\RoboLife_Farm


# Camera
DEFAULT_CAMERA_SECONDS=10

# Fixed commands only. Do not put user-provided raw command here at runtime.
BUILD_COMMAND=python --version
FLASH_COMMAND=python --version
COMMAND_TIMEOUT_SECONDS=300

# Serial
SERIAL_PORT=COM3
SERIAL_BAUDRATE=115200
SERIAL_READ_SECONDS=10

# Telegram log output limit
LOG_TAIL_LINES=80

# Auto task worker
# AUTO_TASK_WORKER_ENABLED=1 enables background task scanning.
# CLINE_TASK_COMMAND is the trusted local command that executes one Telegram task.
# The command receives env vars: TASK_ID, TASK_FILE, TASK_REQUEST, PROJECT_ROOT.
AUTO_TASK_WORKER_ENABLED=1
TASK_POLL_SECONDS=5
CLINE_TASK_COMMAND=python -m telegram_control.services.local_task_executor
AUTO_PUSH_BRANCH=devQuang

# Project run/stop command used by /run_project and /stop_project
RUN_PROJECT_COMMAND=python Project_Farm_Here/opencv_camera.py

# AI DevOps executor
AI_DEVOPS_ENABLED=1
AI_TASK_POLL_SECONDS=5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
MAX_SOURCE_CHARS=120000
